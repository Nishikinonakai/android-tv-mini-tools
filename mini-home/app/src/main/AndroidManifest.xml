<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <!-- Normal permission, auto-granted; required since API 26 for ACTION_DELETE -->
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <!-- App-manager / one-tap clean. The signature|privileged ones only grant
         because the launcher is whitelisted as a priv-app — see
         privapp-permissions-com.zy.tvhome.xml. Without the allowlist the code
         degrades gracefully (gentle kill, no autostart toggle). -->
    <uses-permission android:name="android.permission.FORCE_STOP_PACKAGES" />
    <uses-permission android:name="android.permission.CHANGE_COMPONENT_ENABLED_STATE" />
    <uses-permission android:name="android.permission.REAL_GET_TASKS" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
        </intent>
    </queries>

    <application
        android:label="@string/app_name"
        android:theme="@style/HomeTheme"
        android:allowBackup="false">

        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:configChanges="keyboardHidden|navigation|orientation|screenSize|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AppManagerActivity"
            android:exported="false"
            android:label="@string/manager_title"
            android:theme="@style/HomeTheme"
            android:configChanges="keyboardHidden|navigation|orientation|screenSize|uiMode" />

    </application>
</manifest>
